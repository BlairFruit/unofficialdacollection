{
  "name": "unofficial-deaxs-adventure-collection",
  "productName": "Unofficial Deaxs Adventure Collection",
  "version": "2.0.0",
  "description": "The Unofficial Collection for the shitty webcomic that chuds like.",
  "main": "main.js",
  "coreFiles": [],
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.blairfruit.deaxsadventure",
    "asar": true,
    "files": [
      "**/*",
      "!assets/media/p*-*.*", 
      "!assets/data.json"
    ],
    "win": {
      "target": "zip",
      "icon": "assets/media/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "dompurify": "^3.4.0",
    "electron-window-state": "^5.0.3"
  }
}